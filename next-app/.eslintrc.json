{
  "extends": [
    "next/core-web-vitals",
    "plugin:jsx-a11y/recommended"
  ],
  "plugins": ["jsx-a11y"],
  "rules": {
    // ── Heading rules ─────────────────────────────────────────────────────────
    // Ensure every heading has non-empty text content
    "jsx-a11y/heading-has-content": "error",

    // ── Image rules ───────────────────────────────────────────────────────────
    // All <img> / <Image> elements must have a meaningful alt attribute
    "jsx-a11y/alt-text": "error",

    // ── Interactive element rules ─────────────────────────────────────────────
    // <a> tags must have discernible text (text or aria-label)
    "jsx-a11y/anchor-has-content": "error",
    // <a> must have a valid href
    "jsx-a11y/anchor-is-valid": "warn",

    // ── ARIA rules ────────────────────────────────────────────────────────────
    // aria-* props must be valid ARIA attributes
    "jsx-a11y/aria-props": "error",
    // aria-* prop values must be valid
    "jsx-a11y/aria-proptypes": "error",
    // Elements with aria roles must use a valid, non-abstract ARIA role
    "jsx-a11y/aria-role": "error",
    // Don't add aria-hidden to elements that are already hidden
    "jsx-a11y/aria-unsupported-elements": "error",

    // ── Button / interactive rules ─────────────────────────────────────────────
    // Buttons must have accessible text (text or aria-label)
    "jsx-a11y/button-has-type": "warn",
    // Interactive elements must be focusable
    "jsx-a11y/interactive-supports-focus": "warn",

    // ── Form rules ────────────────────────────────────────────────────────────
    // Every <label> must be associated with a form element
    "jsx-a11y/label-has-associated-control": "warn",

    // ── Language rule ─────────────────────────────────────────────────────────
    // <html> must have a lang attribute — already set to "en" in layout.tsx
    "jsx-a11y/html-has-lang": "error"
  }
}
